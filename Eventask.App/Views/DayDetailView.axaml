<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:Eventask.App.ViewModels"
             xmlns:cv="clr-namespace:Eventask.App.Converters"
             mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="700"
             x:DataType="vm:DayDetailViewModel"
             x:Class="Eventask.App.Views.DayDetailView">

	<UserControl.Resources>
		<cv:BoolToTextDecorationsConverter x:Key="BoolToTextDecorationsConverter"/>
		<cv:ObjectToVisibilityConverter x:Key="ObjectToVisibilityConverter"/>
		<SolidColorBrush x:Key="PrimaryRed">#FF3B30</SolidColorBrush>
		<SolidColorBrush x:Key="TextBlack">#1C1C1E</SolidColorBrush>
		<SolidColorBrush x:Key="TextGray">#8E8E93</SolidColorBrush>
		<SolidColorBrush x:Key="BackgroundGray">#F5F5F5</SolidColorBrush>
	</UserControl.Resources>

	<UserControl.Styles>
		<Style Selector="Button.Ghost">
			<Setter Property="Background" Value="Transparent"/>
			<Setter Property="BorderThickness" Value="0"/>
			<Setter Property="Padding" Value="0"/>
		</Style>

		<Style Selector="Border.ScheduleCard">
			<Setter Property="Background" Value="White"/>
			<Setter Property="CornerRadius" Value="8"/>
			<Setter Property="Padding" Value="12"/>
			<Setter Property="Margin" Value="0,0,0,8"/>
		</Style>
	</UserControl.Styles>

	<Grid RowDefinitions="60, *">
		<!-- 顶部导航栏 -->
		<Grid Grid.Row="0" Background="{DynamicResource BackgroundGray}" ColumnDefinitions="Auto, *, Auto, Auto">
			<Button Grid.Column="0" Classes="Ghost" Command="{Binding GoBackCommand}" 
					Margin="15,0" VerticalAlignment="Center">
				<StackPanel Orientation="Horizontal" Spacing="5">
					<PathIcon Data="M15.41 7.41L14 6l-6 6 6 6 1.41-1.41L10.83 12z" 
							  Foreground="{DynamicResource PrimaryRed}" Height="20" Width="20"/>
					<TextBlock Text="返回" Foreground="{DynamicResource PrimaryRed}" 
							   FontSize="16" VerticalAlignment="Center"/>
				</StackPanel>
			</Button>

			<TextBlock Grid.Column="1" Text="{Binding DateHeaderText}" 
					   HorizontalAlignment="Center" VerticalAlignment="Center"
					   FontSize="18" FontWeight="Bold" Foreground="{DynamicResource TextBlack}"/>

			<Button Grid.Column="2" Classes="Ghost" Command="{Binding RecognizeWithAiCommand}" 
					Margin="0,0" VerticalAlignment="Center" ToolTip.Tip="AI 识别">
				<StackPanel Orientation="Horizontal" Spacing="6">
					<PathIcon Data="M13 2L3 14h7l-1 8 10-12h-7l1-8z" Foreground="{DynamicResource PrimaryRed}" Height="20" Width="20"/>
					<TextBlock Text="AI" Foreground="{DynamicResource PrimaryRed}" FontSize="14"/>
				</StackPanel>
			</Button>

			<Button Grid.Column="3" Classes="Ghost" Command="{Binding AddEventCommand}" 
					Margin="15,0" VerticalAlignment="Center" ToolTip.Tip="新建日程">
				<TextBlock Text="+" FontSize="32" Foreground="{DynamicResource PrimaryRed}" Margin="0,-8,0,0"/>
			</Button>
		</Grid>

		<!-- 内容区域 -->
		<ScrollViewer Grid.Row="1" Margin="15,10,15,0">
			<StackPanel Spacing="15">
				
				<!-- 日程部分：显示当天的事件列表 -->
<StackPanel IsVisible="{Binding Events.Count}">  <!-- 有事件时才显示 -->
    <!-- 标题 -->
    <TextBlock Text="日程" FontSize="20" FontWeight="Bold" 
               Foreground="{DynamicResource TextBlack}" Margin="0,0,0,10"/>
    
    <!-- 事件列表 -->
    <ItemsControl ItemsSource="{Binding Events}">
        <ItemsControl.ItemTemplate>
            <DataTemplate>
                <!-- 事件卡片 -->
                <Border Classes="ScheduleCard">
                    <Grid RowDefinitions="Auto, Auto, Auto, Auto" ColumnDefinitions="*, Auto">
                        <!-- 事件标题 -->
                        <TextBlock Grid.Row="0" Grid.Column="0" 
                                   Text="{Binding Title}" 
                                   FontSize="16" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextBlack}"
                                   TextWrapping="Wrap"/>
                        
                        <!-- 时间信息（带时钟图标） -->
                        <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" 
                                    Orientation="Horizontal" Spacing="8" Margin="0,4,0,0">
                            <!-- 时钟图标 -->
                            <PathIcon Data="M11.99 2C6.47 2 2 6.48 2 12s4.47 10 9.99 10C17.52 22 22 17.52 22 12S17.52 2 11.99 2zM12 20c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8zm.5-13H11v6l5.25 3.15.75-1.23-4.5-2.67z"
                                  Foreground="{DynamicResource TextGray}" Height="14" Width="14"/>
                            <!-- 时间范围文本 -->
                            <TextBlock Text="{Binding TimeRangeText}" 
                                       FontSize="14" Foreground="{DynamicResource TextGray}"/>
                        </StackPanel>
                        
                        <!-- 地点信息（有地点时才显示） -->
                        <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" 
                                    Orientation="Horizontal" Spacing="8" Margin="0,4,0,0"
                                    IsVisible="{Binding Location, Converter={StaticResource ObjectToVisibilityConverter}}">
                            <!-- 地点图标 -->
                            <PathIcon Data="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"
                                  Foreground="{DynamicResource TextGray}" Height="14" Width="14"/>
                            <!-- 地点文本 -->
                            <TextBlock Text="{Binding Location}" 
                                       FontSize="14" Foreground="{DynamicResource TextGray}"/>
                        </StackPanel>
                        
                        <!-- 描述信息（有描述时才显示） -->
                        <TextBlock Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2" 
                                   Text="{Binding Description}" 
                                   FontSize="14" Foreground="{DynamicResource TextGray}"
                                   TextWrapping="Wrap" Margin="0,4,0,0"
                                   IsVisible="{Binding Description, Converter={StaticResource ObjectToVisibilityConverter}}"/>
                        
                        <!-- 操作按钮：编辑和删除 -->
                        <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Spacing="8">
                            <!-- 编辑按钮 -->
                            <Button Classes="Ghost" 
                                    Command="{Binding $parent[UserControl].((vm:DayDetailViewModel)DataContext).EditItemCommand}"
                                    CommandParameter="{Binding}">
                                <!-- 编辑图标 -->
                                <PathIcon Data="M3 17.25V21h3.75L17.81 9.94l-3.75-3.75L3 17.25zM20.71 7.04c.39-.39.39-1.02 0-1.41l-2.34-2.34c-.39-.39-1.02-.39-1.41 0l-1.83 1.83 3.75 3.75 1.83-1.83z"
                                          Foreground="{DynamicResource TextGray}" Height="16" Width="16"/>
                            </Button>
                            <!-- 删除按钮 -->
                            <Button Classes="Ghost" 
                                    Command="{Binding $parent[UserControl].((vm:DayDetailViewModel)DataContext).DeleteItemCommand}"
                                    CommandParameter="{Binding}">
                                <!-- 删除图标（红色） -->
                                <PathIcon Data="M6 19c0 1.1.9 2 2 2h8c1.1 0 2-.9 2-2V7H6v12zM19 4h-3.5l-1-1h-5l-1 1H5v2h14V4z"
                                          Foreground="{DynamicResource PrimaryRed}" Height="16" Width="16"/>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>
            </DataTemplate>
        </ItemsControl.ItemTemplate>
    </ItemsControl>
</StackPanel>

<!-- 任务部分：显示当天的任务列表 -->
<StackPanel IsVisible="{Binding Tasks.Count}">  <!-- 有任务时才显示 -->
    <!-- 标题 -->
    <TextBlock Text="任务" FontSize="20" FontWeight="Bold" 
               Foreground="{DynamicResource TextBlack}" Margin="0,0,0,10"/>
    
    <!-- 任务列表 -->
    <ItemsControl ItemsSource="{Binding Tasks}">
        <ItemsControl.ItemTemplate>
            <DataTemplate>
                <!-- 任务卡片 -->
                <Border Classes="ScheduleCard">
                    <Grid RowDefinitions="Auto, Auto, Auto" ColumnDefinitions="Auto, *, Auto">
                        <!-- 完成状态复选框（单向绑定+命令） -->
                        <CheckBox Grid.Row="0" Grid.Column="0" 
                                  IsChecked="{Binding IsCompleted, Mode=OneWay}" 
                                  Command="{Binding $parent[UserControl].((vm:DayDetailViewModel)DataContext).ToggleTaskCompleteCommand}"
                                  CommandParameter="{Binding}"
                                  VerticalAlignment="Center" Margin="0,0,10,0"/>
                        
                        <!-- 任务标题（已完成显示删除线） -->
                        <TextBlock Grid.Row="0" Grid.Column="1" 
                                   Text="{Binding Title}" 
                                   FontSize="16" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextBlack}"
                                   TextWrapping="Wrap"
                                   TextDecorations="{Binding IsCompleted, Converter={StaticResource BoolToTextDecorationsConverter}}"/>  <!-- 已完成则添加删除线 -->
                        
                        <!-- 截止时间（有时限时才显示） -->
                        <StackPanel Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" 
                                    Orientation="Horizontal" Spacing="8" Margin="0,4,0,0"
                                    IsVisible="{Binding DueTime, Converter={StaticResource ObjectToVisibilityConverter}}">
                            <!-- 时钟图标 -->
                            <PathIcon Data="M11.99 2C6.47 2 2 6.48 2 12s4.47 10 9.99 10C17.52 22 22 17.52 22 12S17.52 2 11.99 2zM12 20c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8zm.5-13H11v6l5.25 3.15.75-1.23-4.5-2.67z"
                                      Foreground="{DynamicResource TextGray}" Height="14" Width="14"/>
                            <!-- 时间范围文本 -->
                            <TextBlock Text="{Binding TimeRangeText}" 
                                       FontSize="14" Foreground="{DynamicResource TextGray}"/>
                        </StackPanel>
                        
                        <!-- 任务描述（有描述时才显示） -->
                        <TextBlock Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2" 
                                   Text="{Binding Description}" 
                                   FontSize="14" Foreground="{DynamicResource TextGray}"
                                   TextWrapping="Wrap" Margin="0,4,0,0"
                                   IsVisible="{Binding Description, Converter={StaticResource ObjectToVisibilityConverter}}"/>
                        
                        <!-- 操作按钮：编辑和删除 -->
                        <StackPanel Grid.Row="0" Grid.Column="2" Orientation="Horizontal" Spacing="8">
                            <!-- 编辑按钮 -->
                            <Button Classes="Ghost" 
                                    Command="{Binding $parent[UserControl].((vm:DayDetailViewModel)DataContext).EditItemCommand}"
                                    CommandParameter="{Binding}">
                                <!-- 编辑图标 -->
                                <PathIcon Data="M3 17.25V21h3.75L17.81 9.94l-3.75-3.75L3 17.25zM20.71 7.04c.39-.39.39-1.02 0-1.41l-2.34-2.34c-.39-.39-1.02-.39-1.41 0l-1.83 1.83 3.75 3.75 1.83-1.83z"
                                          Foreground="{DynamicResource TextGray}" Height="16" Width="16"/>
                            </Button>
                            <!-- 删除按钮 -->
                            <Button Classes="Ghost" 
                                    Command="{Binding $parent[UserControl].((vm:DayDetailViewModel)DataContext).DeleteItemCommand}"
                                    CommandParameter="{Binding}">
                                <!-- 删除图标（红色） -->
                                <PathIcon Data="M6 19c0 1.1.9 2 2 2h8c1.1 0 2-.9 2-2V7H6v12zM19 4h-3.5l-1-1h-5l-1 1H5v2h14V4z"
                                          Foreground="{DynamicResource PrimaryRed}" Height="16" Width="16"/>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>
            </DataTemplate>
        </ItemsControl.ItemTemplate>
    </ItemsControl>
</StackPanel>

				<!-- 无数据提示 -->
				<StackPanel IsVisible="{Binding !HasSchedule}" Margin="0,50,0,0">
					<TextBlock Text="📅" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,10"/>
					<TextBlock Text="今天还没有安排" FontSize="16" 
							   Foreground="{DynamicResource TextGray}" HorizontalAlignment="Center"/>
					<Button Content="添加日程或任务" Command="{Binding AddEventCommand}"
							Background="{DynamicResource PrimaryRed}" Foreground="White"
							HorizontalAlignment="Center" Margin="0,20,0,0" Padding="20,10"
							CornerRadius="8"/>
				</StackPanel>
			</StackPanel>
		</ScrollViewer>
	</Grid>
</UserControl>