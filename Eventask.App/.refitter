{
  "openApiPath": "https://localhost:7473/openapi/v1.json",
  "namespace": "Eventask.App.Services.Generated",
  "naming": {
    "useOpenApiTitle": false,
    "interfaceName": "EventaskApi"
  },
  "generateContracts": false,
  "addAutoGeneratedHeader": true,
  "addAcceptHeaders": true,
  "generateXmlDocCodeComments": true,
  "generateStatusCodeComments": true,
  "useCancellationTokens": true,
  "generateNullableReferenceTypes": true,
  "operationNameTemplate": "{operationName}Async",
  "responseTypeOverride": {
    "Attachments_Download": "System.Net.Http.HttpResponseMessage"
  },
  "outputFolder": "./Services/Generated",
  "outputFilename": "EventaskApi.g.cs",
  "additionalNamespaces": [
    "Eventask.Domain.Dtos",
    "Eventask.Domain.Requests",
    "System.Net.Http"
  ]
}
